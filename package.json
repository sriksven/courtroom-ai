{
  "name": "all-rise",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"API,AGENT,UI\" --prefix-colors \"cyan,yellow,green\" \"node dev-server.js\" \"cd agent && node index.js dev\" \"vite\"",
    "dev:no-agent": "node dev-server.js & vite",
    "agent": "cd agent && node index.js dev",
    "agent:voice": "cd agent && npm run dev:voice",
    "api": "node dev-server.js",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:once": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "groq-sdk": "^1.1.2",
    "livekit-client": "^2.5.0",
    "livekit-server-sdk": "^2.7.0",
    "openai": "^4.67.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsdom": "^25.0.1",
    "playwright": "^1.48.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
